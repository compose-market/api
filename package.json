{
  "name": "compose-market-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && esbuild index.ts --bundle --platform=node --target=node25 --format=cjs --outfile=dist/index.cjs --minify && npm run copy-data",
    "deploy": "npx tsx deploy.ts --fast",
    "deploy:fast": "npx tsx deploy.ts --fast",
    "deploy:checked": "npm run build && npx tsx deploy.ts --fast",
    "deploy:full": "npm run build && npx tsx deploy.ts",
    "copy-data": "mkdir -p dist/data && cp -f inference/data/params/video.json inference/data/params/image.json inference/data/models.json inference/data/models_extended.json dist/data/ 2>/dev/null || echo 'Note: Some data files not found'",
    "sync-models": "cd shared/models/scripts && npx tsx sync-models.ts",
    "dev": "tsx index.ts",
    "knowledge:mcp-index": "node --import tsx knowledge/mcp-indexer.ts",
    "check:inference": "tsx scripts/check.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@composio/core": "^0.6.8",
    "@filoz/synapse-core": "^0.4.0",
    "@filoz/synapse-sdk": "^0.40.3",
    "filecoin-pin": "^0.20.0",
    "@google/genai": "^1.48.0",
    "@huggingface/inference": "^4.13.15",
    "@x402/core": "^2.9.0",
    "@x402/evm": "^2.9.0",
    "ai": "^6.0.146",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "puppeteer": "^24.40.0",
    "redis": "^5.11.0",
    "viem": "^2.47.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "ajv": "^8.18.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
