{
  "name": "compose-market-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild handler.ts --bundle --platform=node --target=node25 --format=cjs --outfile=dist/index.js --minify && npm run copy-data",
    "copy-data": "mkdir -p dist/data && cp -f shared/models/data/params/video.json shared/models/data/params/image.json shared/models/data/models.json shared/models/data/models_extended.json dist/data/ 2>/dev/null || echo 'Note: Some data files not found'",
    "deploy": "npm run build && npx serverless deploy --verbose",
    "deploy:domain": "npx serverless create_domain",
    "deploy:quick": "tsx deploy.ts",
    "sync-models": "cd shared/models/scripts && npx tsx sync-models.ts",
    "dev": "tsx index.ts",
    "knowledge:mcp-index": "node --import tsx knowledge/mcp-indexer.ts"
  },
  "dependencies": {
    "@ai-ml.api/aimlapi-vercel-ai": "^1.0.2",
    "@ai-sdk/anthropic": "^3.0.36",
    "@ai-sdk/google": "^3.0.20",
    "@ai-sdk/openai": "^3.0.25",
    "@ai-sdk/openai-compatible": "^2.0.26",
    "@crypto.com/facilitator-client": "^1.0.4",
    "@google/genai": "^1.39.0",
    "@hono/node-server": "^1.19.9",
    "@huggingface/hub": "^2.8.1",
    "@huggingface/inference": "^4.13.11",
    "@langchain/anthropic": "^1.3.14",
    "@langchain/core": "^1.1.19",
    "@openrouter/sdk": "^0.5.1",
    "@x402/core": "^2.2.0",
    "@x402/evm": "^2.2.0",
    "@x402/hono": "^2.2.0",
    "ai": "^6.0.69",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "hono": "^4.11.7",
    "mem0ai": "^1.0.39",
    "puppeteer": "^24.36.1",
    "redis": "^5.10.0",
    "thirdweb": "^5.118.0",
    "viem": "^2.45.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.0",
    "ajv": "^8.17.1",
    "esbuild": "^0.27.2",
    "serverless": "^4.31.2",
    "serverless-domain-manager": "^9.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
