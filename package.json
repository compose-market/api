{
  "name": "compose-market-api",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "esbuild handler.ts --bundle --platform=node --target=node25 --format=cjs --outfile=dist/index.js --minify && npm run copy-data",
    "copy-data": "mkdir -p dist/data && cp -f shared/models/data/params/video.json shared/models/data/params/image.json shared/models/data/models.json shared/models/data/models_extended.json dist/data/ 2>/dev/null || echo 'Note: Some data files not found'",
    "deploy": "npm run build && npx serverless deploy --verbose",
    "deploy:domain": "npx serverless create_domain",
    "deploy:quick": "tsx deploy.ts",
    "sync-models": "cd shared/models/scripts && npx tsx sync-models.ts",
    "dev": "tsx index.ts"
  },
  "dependencies": {
    "@ai-ml.api/aimlapi-vercel-ai": "^1.0.2",
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/google": "^3.0.13",
    "@ai-sdk/openai": "^3.0.19",
    "@ai-sdk/openai-compatible": "^2.0.18",
    "@crypto.com/facilitator-client": "^1.0.4",
    "@google/genai": "^1.38.0",
    "@huggingface/hub": "^2.7.2",
    "@huggingface/inference": "^4.13.10",
    "@openrouter/sdk": "^0.4.0",
    "ai": "^6.0.49",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "mem0ai": "^2.2.1",
    "puppeteer": "^24.36.0",
    "redis": "^5.10.0",
    "thirdweb": "^5.118.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.10",
    "ajv": "^8.17.1",
    "esbuild": "^0.27.2",
    "serverless": "^4.31.0",
    "serverless-domain-manager": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
